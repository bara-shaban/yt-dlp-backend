{
  "expo": {
    "name": "AI-Wa7shTube",
    "slug": "ai-wa7shtube-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aiwa7shtube",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.bara.aiwa7shtube",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSLocalNetworkUsageDescription": "AI-Wa7shTube uses the local network to find Chromecast devices and connect to your resolver while developing.",
        "NSBonjourServices": [
          "_googlecast._tcp",
          "_CC1AD845._googlecast._tcp"
        ],
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.bara.aiwa7shtube",
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "INTERNET",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0f0f0f"
      }
    },
    "plugins": [
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "react-native-google-cast",
        {
          "receiverAppId": "CC1AD845"
        }
      ]
    ]
  }
}
